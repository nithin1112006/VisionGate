# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's environment. But for a standalone application, you might
#   want to commit them.
# .python-version

# pipenv
#   According to pypa/pipenv#1256, Pipfile.lock should be committed unless the packaging
#   status of the project is a library.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be committed unless the packaging status
#   of the project is a library.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock should be committed unless the packaging status
#   of the project is a library.
#.pdm.toml
.pdm-plugins/
.pdm-build/

# PEP 582; HTML generator templates for amara3
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

