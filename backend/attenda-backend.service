[Unit]
Description=Attenda Backend FastAPI Service
After=network.target postgresql.service

[Service]
User=techpark-2
WorkingDirectory=/var/www/attenda/backend
ExecStart=/var/www/attenda/backend/.venv/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
Environment=PATH=/var/www/attenda/backend/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=multi-user.target
